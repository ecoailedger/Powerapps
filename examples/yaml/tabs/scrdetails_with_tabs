                                                            LayoutMaxHeight: =
                                                            LayoutMaxWidth: =
                                                            OnSelect: "=/*\nWith(\n    {\n        // Current context - we're ON a Fund Job, allocating FROM a PO\n        _fundJobId: gvar_Selected_FundJob.id,\n        _fundJobBudget: gvar_Selected_FundJob.predicted_cost,\n        _periodId: gvar_currentPeriodRecord.id,\n        _userId: User().EntraObjectId,\n        _userName: User().FullName,\n        \n        // From form inputs\n        _poId: cmb_FundJob_namePO_4.Selected.id,\n        _poNumber: cmb_FundJob_namePO_4.Selected.po_number,\n        _amount: Value(txtAddAmount_4.Text),\n        \n        // Current totals for validation\n        _currentPOAllocated: Sum(\n            Filter(galAlloc_1.AllItems, po_id = cmb_FundJob_namePO_4.Selected.id),\n            amount\n        ),\n        _poTotalValue: cmb_FundJob_namePO_4.Selected.total_value_raw,\n        _currentFundJobAllocated: Sum(galAlloc_1.AllItems, amount)\n    },\n    \n    // Validation chain\n    If(\n        IsBlank(_poId),\n        Notify(\"Please select a Purchase Order.\", NotificationType.Error),\n        \n        If(\n            IsBlank(_amount) || _amount <= 0,\n            Notify(\"Please enter a valid amount greater than 0.\", NotificationType.Error),\n            \n            If(\n                (_currentPOAllocated + _amount) > _poTotalValue,\n                Notify(\n                    \"Allocation exceeds PO value. PO \" & _poNumber & \" has £\" & \n                    Text(_poTotalValue, \"#,##0.00\") & \n                    \" total, already allocated £\" & Text(_currentPOAllocated, \"#,##0.00\") & \n                    \", your £\" & Text(_amount, \"#,##0.00\") & \n                    \" would exceed by £\" & Text((_currentPOAllocated + _amount) - _poTotalValue, \"#,##0.00\"),\n                    NotificationType.Error\n                ),\n                \n                If(\n                    (_currentFundJobAllocated + _amount) > _fundJobBudget,\n                    Notify(\n                        \"Allocation exceeds Fund-Job budget. \" & \n                        gvar_Selected_FundJob.job_name & \n                        \" has budget £\" & Text(_fundJobBudget, \"#,##0.00\") & \n                        \", already allocated £\" & Text(_currentFundJobAllocated, \"#,##0.00\") & \n                        \", your £\" & Text(_amount, \"#,##0.00\") & \n                        \" would exceed by £\" & Text((_currentFundJobAllocated + _amount) - _fundJobBudget, \"#,##0.00\"),\n                        NotificationType.Error\n                    ),\n                    \n                    // All validations passed - create the allocation\n                    ClearCollect(\n                        ColFundJobAllocations,\n                        'mosaic-dev'.dbospUpsertPoAllocation({\n                            mode: \"FUNDJOB\",\n                            fund_job_id: _fundJobId,\n                            po_id: _poId,\n                            period_id: _periodId,\n                            amount: _amount,\n                            user_id: _userId,\n                            user_name: _userName\n                        }).ResultSets.Table1\n                    );\n                    \n                    // Reset form\n                    Reset(cmb_FundJob_namePO_4);\n                    Reset(txtAddAmount_4);\n                    SetFocus(cmb_FundJob_namePO_4);\n                    \n                    // Refresh the Fund Job totals\n                    Set(temp_FundJobID, gvar_Selected_FundJob.id);\n                    ClearCollect(ColFundJobs, 'mosaic-dev'.dbospGetFundJobs().ResultSets.Table1);\n                    Set(gvar_Selected_FundJob, First(Filter(ColFundJobs, id = temp_FundJobID)));\n                    \n                    Notify(\"Allocation added successfully - £\" & Text(_amount, \"#,##0.00\") & \" from PO \" & _poNumber, NotificationType.Success)\n                )\n            )\n        )\n    )\n);\n*/\nWith(\n    {\n        // Current context\n        _fundJobId: gvar_Selected_FundJob.id,\n        _periodId: gvar_currentPeriodRecord.id,\n        _userId: User().EntraObjectId,\n        _userName: User().FullName,\n        \n        // From form inputs\n        _poId: cmb_FundJob_namePO_4.Selected.id,\n        _poNumber: cmb_FundJob_namePO_4.Selected.po_number,\n        _amount: Value(txtAddAmount_4.Text),\n        \n        // PO validation - use ColAllocations (global, all fund jobs) NOT galAlloc_1\n        // galAlloc_1 is scoped to this fund job only, so summing it misses allocations\n        // against the same PO from other fund jobs, allowing over-allocation\n        _poTotalValue: cmb_FundJob_namePO_4.Selected.total_value_raw,\n        _currentPOAllocated: Sum(\n            Filter(ColAllocations, po_id = cmb_FundJob_namePO_4.Selected.id),\n            amount\n        )\n    },\n    \n    If(\n        IsBlank(_poId),\n        Notify(\"Please select a Purchase Order.\", NotificationType.Error),\n        \n        If(\n            IsBlank(_amount) || _amount <= 0,\n            Notify(\"Please enter a valid amount greater than 0.\", NotificationType.Error),\n            \n            If(\n                (_currentPOAllocated + _amount) > _poTotalValue,\n                Notify(\n                    \"Allocation exceeds PO value. PO \" & _poNumber & \" has £\" & \n                    Text(_poTotalValue, \"#,##0.00\") & \n                    \" total, already allocated £\" & Text(_currentPOAllocated, \"#,##0.00\") & \n                    \", your £\" & Text(_amount, \"#,##0.00\") & \n                    \" would exceed by £\" & Text((_currentPOAllocated + _amount) - _poTotalValue, \"#,##0.00\"),\n                    NotificationType.Error\n                ),\n                \n                // All validations passed - create allocation\n                ClearCollect(\n                    ColFundJobAllocations,\n                    'mosaic-dev'.dbospUpsertPoAllocation({\n                        mode: \"FUNDJOB\",\n                        fund_job_id: _fundJobId,\n                        po_id: _poId,\n                        period_id: _periodId,\n                        amount: _amount,\n                        user_id: _userId,\n                        user_name: _userName\n                    }).ResultSets.Table1\n                );\n                \n                // Keep ColAllocations in sync so PO validation stays accurate\n                // for any subsequent allocations in this session\n                Collect(\n                    ColAllocations,\n                    {po_id: _poId, fund_job_id: _fundJobId, amount: _amount, period_id: _periodId}\n                );\n                \n                // Reset form\n                Reset(cmb_FundJob_namePO_4);\n                Reset(txtAddAmount_4);\n                SetFocus(cmb_FundJob_namePO_4);\n                \n                // Refresh Fund Job totals only - do NOT touch ColPOs, PO total value never changes\n                Set(temp_FundJobID, gvar_Selected_FundJob.id);\n                ClearCollect(ColFundJobs, 'mosaic-dev'.dbospGetFundJobs().ResultSets.Table1);\n                Set(gvar_Selected_FundJob, First(Filter(ColFundJobs, id = temp_FundJobID)));\n                \n                Notify(\"Allocation added successfully - £\" & Text(_amount, \"#,##0.00\") & \" from PO \" & _poNumber, NotificationType.Success)\n            )\n        )\n    )\n);"
